# ─────────────────────────────────────────────
# 달디단 (Daldidan) — 환경 변수 템플릿
# 이 파일을 복사해 .env.local 로 저장한 후 값을 채우세요.
# ─────────────────────────────────────────────

# 사이트 기본 URL (이메일 링크, 알림톡 딥링크 등에 사용)
# 프로덕션에서는 실제 공개 도메인을 반드시 넣으세요.
# 예: https://daldidan.vercel.app  또는 로컬: http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# ── Firebase Cloud Messaging (웹 푸시) ────────────────────────
# Firebase Console > 프로젝트 설정 > 일반 / Cloud Messaging 에서 확인
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# 서버 전용 Firebase Admin 자격 증명
# 둘 중 하나를 사용하세요.
# 1) 개별 필드 3개
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
# 2) 서비스 계정 JSON 전체 문자열 1개
FIREBASE_ADMIN_CREDENTIALS_JSON=

# ── Supabase ──────────────────────────────────
# https://supabase.com/dashboard/project/_/settings/api 에서 확인
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=     # 서버 전용 — 절대 클라이언트에 노출 금지

# ── Google Maps ───────────────────────────────
# https://console.cloud.google.com/apis/credentials 에서 발급
# Maps JavaScript API + Places API 활성화 필요
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=

# ── NAVER CLOVA OCR Receipt ───────────────────
# NAVER Cloud Platform > CLOVA OCR > Document 도메인(Receipt) 생성 후 확인
# Invoke URL은 APIGW 자동 연동으로 발급된 Receipt용 주소를 그대로 사용하세요.
# Secret Key는 도메인 상세에서 확인할 수 있습니다.
NAVER_CLOVA_OCR_INVOKE_URL=
NAVER_CLOVA_OCR_SECRET_KEY=

# ── 한국관광공사 TourAPI 4.0 ──────────────────
# https://apis.data.go.kr 에서 발급
TOUR_API_KEY=

# ── 서울 공공 데이터 API ──────────────────────
# https://data.seoul.go.kr 에서 발급
# 축제 데이터에 사용
SEOUL_OPEN_API_KEY=

# ── 카카오 JavaScript SDK ─────────────────────
# https://developers.kakao.com → 앱 생성 → 앱 키 → JavaScript 키
# 블로그 카카오 공유 버튼에 사용; 미설정 시 버튼 비활성화
NEXT_PUBLIC_KAKAO_JS_KEY=

# ── 카카오 알림톡 (선택) ──────────────────────
# https://business.kakao.com 에서 비즈니스 채널 등록 후 발급
# 미설정 시 알림톡 발송 스킵 (에러 없음)
KAKAO_ALIMTALK_API_KEY=
KAKAO_ALIMTALK_SENDER=
KAKAO_ALIMTALK_TEMPLATE=

# ── Resend (블로그 발행 이메일 알림) ──────────
# https://resend.com/api-keys 에서 발급
# 미설정 시 이메일 알림 스킵 (에러 없음)
RESEND_API_KEY=
RESEND_FROM_EMAIL=   # 예: 달디단 <noreply@yourdomain.com>

# ── 댓글 비밀번호 보안 ────────────────────────
# HMAC-SHA256 시크릿 키 (랜덤 32자 이상 문자열 권장)
# 미설정 시 기본값 사용 — 프로덕션에서는 반드시 설정할 것
COMMENT_PASSWORD_SECRET=
